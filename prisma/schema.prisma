generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  apps      App[]
  users     User[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Template {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  category       String
  complexity     String   // "Simple" | "Moderate" | "Advanced"
  description    String
  tags           String[] // for keyword matching
  schemaDefaults Json     // default component/field structure
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  apps           App[]
}

model App {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  templateId     String
  template       Template        @relation(fields: [templateId], references: [id])
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  schemas        RuntimeSchema[]
  previews       PreviewSnapshot[]
}

model RuntimeSchema {
  id        String          @id @default(cuid())
  appId     String
  app       App             @relation(fields: [appId], references: [id])
  version   Int
  schema    Json            // full schema object
  createdAt DateTime        @default(now())
  isCurrent Boolean         @default(false)
  versions  SchemaVersion[]

  @@unique([appId, version])
}

model SchemaVersion {
  id              String        @id @default(cuid())
  runtimeSchemaId String
  runtimeSchema   RuntimeSchema @relation(fields: [runtimeSchemaId], references: [id])
  version         Int
  schema          Json
  createdAt       DateTime      @default(now())
}

model PreviewSnapshot {
  id        String   @id @default(cuid())
  appId     String
  app       App      @relation(fields: [appId], references: [id])
  token     String   @unique
  schema    Json     // frozen snapshot — never updated
  expiresAt DateTime?
  createdAt DateTime @default(now())
}
